# Optional environment overrides for resl-kanban.
# Copy to `.env.local` and adjust as needed. Vite only exposes vars
# prefixed with VITE_ to client code.

# Override the AGOL OAuth Client ID. Defaults to the dedicated
# Resource Deployment Kanban app registration.
# VITE_CLIENT_ID=ylEHpMx1WynLwVf2

# Override the redirect URI. By default the app uses window.location's
# origin + directory, which means localhost dev "just works" once you've
# added http://localhost:5173/ to the AGOL app's redirect URI list.
# VITE_REDIRECT_URI=http://localhost:5173/

# Override the feature service URL & layer.
# VITE_SERVICE_URL=https://services1.arcgis.com/kILp9lqGUeOhnDbI/ArcGIS/rest/services/Mobilization_MCC_Tracking_Resource_Repeat_View/FeatureServer/1
